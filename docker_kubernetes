🧩 STEP 6: Jenkins Pipeline Setup

Open 👉 Jenkins

🔹 Create New Job
Click New Item
Name: rivera-pipeline
Select Pipeline
🔹 Add Pipeline Script
📄 Jenkinsfile
pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/YOUR_USERNAME/rivera-ci-cd.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t rivera-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker rm -f rivera-container || true'
                bat 'docker run -d -p 8081:80 --name rivera-container rivera-app'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                bat 'kubectl apply -f deployment.yaml'
                bat 'kubectl apply -f service.yaml'
            }
        }
    }
}
🧩 STEP 7: Kubernetes Setup

Use 👉 Kubernetes

You can use:

Minikube OR Docker Desktop Kubernetes
🔹 Create deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: rivera-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: rivera
  template:
    metadata:
      labels:
        app: rivera
    spec:
      containers:
      - name: rivera-container
        image: rivera-app
        ports:
        - containerPort: 80
🔹 Create service.yaml
apiVersion: v1
kind: Service
metadata:
  name: rivera-service
spec:
  type: NodePort
  selector:
    app: rivera
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
      nodePort: 30007

command in vs code 
        git init 
        git add deployment.yaml
        git commit -m "updated"
        git push

        git init
        git add service.yaml
        git commit -m "Updated"
        git push
        
🧩 STEP 8: Apply Kubernetes
